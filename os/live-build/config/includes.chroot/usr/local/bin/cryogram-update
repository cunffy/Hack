#!/bin/bash
# cryogram-update — pull latest Cryogram app code and redeploy in-place.
# No ISO rebuild needed for UI/feature changes.
# Usage: sudo cryogram-update

set -euo pipefail

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; NC='\033[0m'

ok()   { echo -e "${GREEN}[OK]${NC}   $1"; }
fail() { echo -e "${RED}[FAIL]${NC} $1"; exit 1; }
info() { echo -e "${CYAN}[INFO]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
step() { echo -e "\n${BOLD}${CYAN}── $1 ──${NC}"; }

# ── Root check ────────────────────────────────────────────────────────────────
if [[ $EUID -ne 0 ]]; then
  echo -e "${RED}Run as root:${NC} sudo cryogram-update"
  exit 1
fi

echo ""
echo -e "${CYAN}${BOLD}╔══════════════════════════════════════════╗${NC}"
echo -e "${CYAN}${BOLD}║      Cryogram OS — App Updater          ║${NC}"
echo -e "${CYAN}${BOLD}╚══════════════════════════════════════════╝${NC}"
echo ""

# ── Config ────────────────────────────────────────────────────────────────────
CONF_FILE="/etc/cryogram/update.conf"
SRC_DIR="/opt/cryogram-src"
APP_DIR="/opt/cryogram"

mkdir -p /etc/cryogram

# Load saved config
if [ -f "$CONF_FILE" ]; then
  # shellcheck source=/dev/null
  source "$CONF_FILE"
fi

# First-run: ask for repo URL
if [ -z "${REPO_URL:-}" ]; then
  echo "First-time setup. Enter the git URL of the Cryogram source repo."
  echo "  Example: https://github.com/yourname/Hack"
  echo ""
  read -rp "  Git repo URL: " REPO_URL
  if [ -z "$REPO_URL" ]; then
    fail "No URL provided. Aborting."
  fi
  {
    echo "# Cryogram update configuration"
    echo "REPO_URL=\"$REPO_URL\""
    echo "BRANCH=\"main\""
  } > "$CONF_FILE"
  ok "Config saved to $CONF_FILE"
fi

BRANCH="${BRANCH:-main}"

# ── Dependency check ──────────────────────────────────────────────────────────
step "Checking dependencies"

missing=()
command -v git  &>/dev/null || missing+=(git)
command -v node &>/dev/null || missing+=(nodejs)
command -v npm  &>/dev/null || missing+=(npm)

if [ ${#missing[@]} -gt 0 ]; then
  info "Installing: ${missing[*]}"
  apt-get update -qq
  apt-get install -y -qq "${missing[@]}"
fi

ok "git $(git --version | awk '{print $3}')  ·  node $(node -v)  ·  npm $(npm -v)"

# ── Fetch latest code ─────────────────────────────────────────────────────────
step "Fetching latest code  ($REPO_URL  [$BRANCH])"

if [ -d "$SRC_DIR/.git" ]; then
  info "Updating existing clone in $SRC_DIR"
  git -C "$SRC_DIR" fetch origin
  git -C "$SRC_DIR" checkout "$BRANCH" 2>/dev/null || true
  git -C "$SRC_DIR" reset --hard "origin/$BRANCH"
  COMMIT=$(git -C "$SRC_DIR" log -1 --format='%h  %s')
  ok "At commit: $COMMIT"
else
  info "Cloning into $SRC_DIR (branch: $BRANCH)"
  git clone --depth=1 --branch "$BRANCH" "$REPO_URL" "$SRC_DIR"
  ok "Cloned."
fi

# ── Install build dependencies ────────────────────────────────────────────────
step "Installing build dependencies  (first run downloads ~300 MB)"

cd "$SRC_DIR"
npm install --loglevel=warn
ok "Dependencies ready"

# ── Build ─────────────────────────────────────────────────────────────────────
step "Building  (takes ~1-2 minutes)"

npm run build
ok "Build complete  ($(du -sh out | cut -f1))"

# ── Deploy ────────────────────────────────────────────────────────────────────
step "Deploying to $APP_DIR"

# Renderer, preload, and main process
rsync -a --delete "$SRC_DIR/out/"         "$APP_DIR/out/"
cp               "$SRC_DIR/package.json"  "$APP_DIR/package.json"

# Python security scripts
[ -d "$SRC_DIR/scripts" ] && rsync -a --delete "$SRC_DIR/scripts/" "$APP_DIR/scripts/"

# Native addons — only sync if newer (node-pty, better-sqlite3)
for dep in node-pty better-sqlite3; do
  if [ -d "$SRC_DIR/node_modules/$dep" ]; then
    rsync -a --delete "$SRC_DIR/node_modules/$dep" "$APP_DIR/node_modules/"
    info "Synced native addon: $dep"
  fi
done

ok "Deployed"

# ── Brave Browser (installs once; skipped if already present) ─────────────────
step "Brave Browser"

if command -v brave-browser &>/dev/null; then
  ok "Brave already installed ($(brave-browser --version 2>/dev/null | head -1 || echo 'version unknown'))"
else
  info "Installing Brave Browser..."
  curl -fsSL https://brave-browser-apt-release.s3.brave.com/brave-browser-archive-keyring.gpg \
    | gpg --dearmor -o /usr/share/keyrings/brave-browser-archive-keyring.gpg 2>/dev/null
  echo "deb [signed-by=/usr/share/keyrings/brave-browser-archive-keyring.gpg arch=amd64] \
    https://brave-browser-apt-release.s3.brave.com/ stable main" \
    > /etc/apt/sources.list.d/brave-browser-release.list
  apt-get update -qq 2>/dev/null
  if DEBIAN_FRONTEND=noninteractive apt-get install -y brave-browser 2>/dev/null; then
    update-alternatives --set x-www-browser /usr/bin/brave-browser 2>/dev/null || true
    ok "Brave Browser installed"
  else
    warn "Brave install failed — try manually: sudo apt install brave-browser"
  fi
fi

# ── Restart Cryogram ─────────────────────────────────────────────────────────
step "Restarting Cryogram"

# Detect the desktop user (the one logged into X, not root)
DESKTOP_USER=$(who | awk '{print $1}' | grep -v root | sort -u | head -1 || true)
if [ -z "$DESKTOP_USER" ]; then
  DESKTOP_USER="cryogram"
fi
DESKTOP_UID=$(id -u "$DESKTOP_USER" 2>/dev/null || echo "1000")

echo ""
warn "Cryogram will close and restart in 3 seconds."
warn "If you are running this from the Cryogram Terminal, that window will close."
echo ""
sleep 3

pkill -f "electron.*cryogram" 2>/dev/null || true
sleep 1

# Relaunch as desktop user with the correct X session environment
DBUS_ADDR="unix:path=/run/user/${DESKTOP_UID}/bus"
sudo -u "$DESKTOP_USER" \
  env DISPLAY=:0 \
      DBUS_SESSION_BUS_ADDRESS="$DBUS_ADDR" \
      XDG_RUNTIME_DIR="/run/user/${DESKTOP_UID}" \
  /usr/local/bin/cryogram &>/dev/null &

disown

ok "Cryogram restarted as $DESKTOP_USER"

echo ""
echo -e "${GREEN}${BOLD}✓  Update complete!${NC}"
echo ""
echo -e "  Run ${CYAN}sudo cryogram-update${NC} anytime to apply new changes."
echo -e "  Edit ${CYAN}$CONF_FILE${NC} to change the repo URL or branch."
echo ""
