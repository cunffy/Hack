#!/bin/bash
# Final system configuration for Cryogram OS
set -e

# --- Locale & timezone ---
echo "en_US.UTF-8 UTF-8" > /etc/locale.gen
locale-gen
update-locale LANG=en_US.UTF-8

# --- Default user: cryogram ---
useradd -m -s /bin/bash -G sudo,audio,video,plugdev,netdev,bluetooth,docker,lp,input cryogram 2>/dev/null || true
echo "cryogram:cryogram" | chpasswd
chage -d 0 cryogram

# --- sudoers ---
echo "cryogram ALL=(ALL) NOPASSWD: /usr/bin/calamares" > /etc/sudoers.d/calamares
echo "cryogram ALL=(ALL) NOPASSWD: /usr/bin/apt-get, /usr/bin/apt" > /etc/sudoers.d/apt

# --- LightDM autologin for live session ---
mkdir -p /etc/lightdm/lightdm.conf.d
cat > /etc/lightdm/lightdm.conf.d/10-autologin.conf << 'EOF'
[Seat:*]
autologin-user=cryogram
autologin-user-timeout=0
user-session=cryogram
EOF

# --- Default session (openbox-session reads autostart automatically) ---
mkdir -p /usr/share/xsessions
cat > /usr/share/xsessions/cryogram.desktop << 'EOF'
[Desktop Entry]
Name=Cryogram
Comment=Cryogram Security OS Desktop
Exec=/usr/local/bin/cryogram-session
TryExec=/usr/local/bin/cryogram-session
Type=Application
DesktopNames=Cryogram
EOF

cat > /usr/local/bin/cryogram-session << 'EOF'
#!/bin/bash
export DISPLAY=:0
export XDG_SESSION_TYPE=x11
export QT_QPA_PLATFORMTHEME=qt5ct
export QT_AUTO_SCREEN_SCALE_FACTOR=1
exec openbox-session
EOF
chmod +x /usr/local/bin/cryogram-session

# --- Openbox autostart (everything that launches at login) ---
mkdir -p /etc/skel/.config/openbox
cat > /etc/skel/.config/openbox/autostart << 'EOF'
#!/bin/bash

# Wallpaper (shown briefly during compositor startup; CyberDen covers it)
feh --bg-fill /usr/share/backgrounds/cryogram/wallpaper.png &

# Compositor (glassmorphism + shadows)
picom --daemon --config /etc/cryogram/picom.conf &

# Notifications daemon (CyberDen forwards via Electron Notification API, but
# system-level notifications (e.g. from terminal tools) still use dunst)
dunst &

# Clipboard manager (system-wide, not Electron-specific)
copyq &

# Screen lock on idle (10 min) and on lid close
xss-lock --transfer-sleep-lock -- i3lock -c 080c12 -e --nofork &

# Touchpad gestures
libinput-gestures-setup start &

# Redshift (adjusts colour temp at night)
redshift-gtk &

# Launch CyberDen as the full desktop shell
# --kiosk disables the Electron menu bar; DISPLAY and home are set by LightDM
sleep 1 && cyberden --start-maximized --no-sandbox &
EOF
chmod +x /etc/skel/.config/openbox/autostart

# --- Openbox rc.xml (keyboard shortcuts + window behaviour) ---
cat > /etc/skel/.config/openbox/rc.xml << 'RCEOF'
<?xml version="1.0" encoding="UTF-8"?>
<openbox_config xmlns="http://openbox.org/3.4/rc"
                xmlns:xi="http://www.w3.org/2001/XInclude">

  <resistance><strength>10</strength><screen_edge_strength>20</screen_edge_strength></resistance>
  <focus><focusNew>yes</focusNew><followMouse>no</followMouse><focusLast>yes</focusLast><underMouse>no</underMouse><focusDelay>200</focusDelay><raiseOnFocus>no</raiseOnFocus></focus>
  <placement><policy>Smart</policy><center>yes</center><monitor>Primary</monitor></placement>
  <theme><name>Clearlooks</name><titleLayout>NLIMC</titleLayout><keepBorder>yes</keepBorder><animateIconify>yes</animateIconify><font place="ActiveWindow"><name>JetBrains Mono</name><size>9</size><weight>Bold</weight><slant>Normal</slant></font><font place="InactiveWindow"><name>JetBrains Mono</name><size>9</size><weight>Normal</weight><slant>Normal</slant></font><font place="MenuHeader"><name>JetBrains Mono</name><size>9</size><weight>Normal</weight><slant>Normal</slant></font><font place="MenuItem"><name>JetBrains Mono</name><size>9</size><weight>Normal</weight><slant>Normal</slant></font><font place="OSD"><name>JetBrains Mono</name><size>10</size><weight>Bold</weight><slant>Normal</slant></font></theme>

  <desktops><number>4</number><firstdesk>1</firstdesk><names><name>Main</name><name>Work</name><name>Gaming</name><name>Monitor</name></names><popupTime>875</popupTime></desktops>

  <resize><drawContents>yes</drawContents><popupShow>Nonpixel</popupShow><popupPosition>Center</popupPosition><popupFixedPosition><x>30</x><y>30</y></popupFixedPosition></resize>

  <applications>
    <!-- CyberDen: full-screen desktop shell, no WM decorations -->
    <application name="cyberden">
      <decor>no</decor>
      <maximized>yes</maximized>
      <fullscreen>no</fullscreen>
      <layer>normal</layer>
      <skip_pager>yes</skip_pager>
      <skip_taskbar>yes</skip_taskbar>
    </application>
    <!-- i3lock overlay -->
    <application name="i3lock">
      <decor>no</decor>
      <layer>above</layer>
    </application>
  </applications>

  <keyboard>
    <!-- App launcher (Super key) -->
    <keybind key="Super_L">
      <action name="Execute"><command>rofi -show drun -theme cryogram</command></action>
    </keybind>
    <keybind key="Super-space">
      <action name="Execute"><command>rofi -show drun -theme cryogram</command></action>
    </keybind>

    <!-- Common app shortcuts -->
    <keybind key="Super-e">
      <action name="Execute"><command>thunar</command></action>
    </keybind>
    <keybind key="Super-b">
      <action name="Execute"><command>opera</command></action>
    </keybind>
    <keybind key="Super-t">
      <action name="Execute"><command>xfce4-terminal</command></action>
    </keybind>
    <keybind key="Super-l">
      <action name="Execute"><command>i3lock -c 080c12 -e</command></action>
    </keybind>

    <!-- Screenshots -->
    <keybind key="Print">
      <action name="Execute"><command>flameshot gui</command></action>
    </keybind>
    <keybind key="Super-Print">
      <action name="Execute"><command>flameshot screen</command></action>
    </keybind>
    <keybind key="A-Print">
      <action name="Execute"><command>flameshot gui</command></action>
    </keybind>

    <!-- Volume keys -->
    <keybind key="XF86AudioRaiseVolume">
      <action name="Execute"><command>/usr/local/bin/cryogram-volume up</command></action>
    </keybind>
    <keybind key="XF86AudioLowerVolume">
      <action name="Execute"><command>/usr/local/bin/cryogram-volume down</command></action>
    </keybind>
    <keybind key="XF86AudioMute">
      <action name="Execute"><command>/usr/local/bin/cryogram-volume mute</command></action>
    </keybind>
    <keybind key="XF86AudioMicMute">
      <action name="Execute"><command>pactl set-source-mute @DEFAULT_SOURCE@ toggle</command></action>
    </keybind>

    <!-- Brightness keys -->
    <keybind key="XF86MonBrightnessUp">
      <action name="Execute"><command>/usr/local/bin/cryogram-brightness up</command></action>
    </keybind>
    <keybind key="XF86MonBrightnessDown">
      <action name="Execute"><command>/usr/local/bin/cryogram-brightness down</command></action>
    </keybind>

    <!-- Window management -->
    <keybind key="A-F4">
      <action name="Close"/>
    </keybind>
    <keybind key="A-Tab">
      <action name="NextWindow"><dialog>icons</dialog><bar>yes</bar><raise>yes</raise></action>
    </keybind>
    <keybind key="A-S-Tab">
      <action name="PreviousWindow"><dialog>icons</dialog><bar>yes</bar><raise>yes</raise></action>
    </keybind>
    <keybind key="Super-d">
      <action name="ToggleShowDesktop"/>
    </keybind>
    <keybind key="Super-h">
      <action name="Iconify"/>
    </keybind>
    <keybind key="Super-m">
      <action name="ToggleMaximize"/>
    </keybind>

    <!-- Snap windows -->
    <keybind key="Super-Left">
      <action name="UnmaximizeFull"/>
      <action name="MoveResizeTo"><x>0</x><y>0</y><width>50%</width><height>100%</height></action>
    </keybind>
    <keybind key="Super-Right">
      <action name="UnmaximizeFull"/>
      <action name="MoveResizeTo"><x>50%</x><y>0</y><width>50%</width><height>100%</height></action>
    </keybind>
    <keybind key="Super-Up">
      <action name="ToggleMaximize"/>
    </keybind>
    <keybind key="Super-Down">
      <action name="UnmaximizeFull"/>
    </keybind>

    <!-- Desktop switching -->
    <keybind key="Super-1"><action name="GoToDesktop"><to>1</to></action></keybind>
    <keybind key="Super-2"><action name="GoToDesktop"><to>2</to></action></keybind>
    <keybind key="Super-3"><action name="GoToDesktop"><to>3</to></action></keybind>
    <keybind key="Super-4"><action name="GoToDesktop"><to>4</to></action></keybind>

    <!-- Session -->
    <keybind key="C-A-Delete">
      <action name="Execute"><command>xfce4-terminal -e htop</command></action>
    </keybind>
    <keybind key="C-A-t">
      <action name="Execute"><command>xfce4-terminal</command></action>
    </keybind>
  </keyboard>

  <mouse>
    <dragThreshold>1</dragThreshold>
    <doubleClickTime>500</doubleClickTime>
    <screenEdgeWarpTime>400</screenEdgeWarpTime>
    <screenEdgeWarpMouse>false</screenEdgeWarpMouse>
    <context name="Frame">
      <mousebind button="A-Left" action="Press"><action name="Focus"/><action name="Raise"/></mousebind>
      <mousebind button="A-Left" action="Click"><action name="Focus"/></mousebind>
      <mousebind button="A-Left" action="Drag"><action name="Move"/></mousebind>
      <mousebind button="A-Right" action="Press"><action name="Focus"/><action name="Raise"/></mousebind>
      <mousebind button="A-Right" action="Drag"><action name="Resize"/></mousebind>
    </context>
    <context name="Desktop">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu"><menu>root-menu</menu></action>
      </mousebind>
    </context>
    <context name="Root">
      <mousebind button="Right" action="Press">
        <action name="ShowMenu"><menu>root-menu</menu></action>
      </mousebind>
    </context>
    <context name="Titlebar">
      <mousebind button="Left" action="Press"><action name="Focus"/><action name="Raise"/></mousebind>
      <mousebind button="Left" action="Drag"><action name="Move"/></mousebind>
      <mousebind button="Left" action="DoubleClick"><action name="ToggleMaximize"/></mousebind>
      <mousebind button="Right" action="Press"><action name="Focus"/><action name="Raise"/><action name="ShowMenu"><menu>client-menu</menu></action></mousebind>
    </context>
    <context name="Close">
      <mousebind button="Left" action="Click"><action name="Close"/></mousebind>
    </context>
    <context name="Maximize">
      <mousebind button="Left" action="Click"><action name="ToggleMaximize"/></mousebind>
    </context>
    <context name="Iconify">
      <mousebind button="Left" action="Click"><action name="Iconify"/></mousebind>
    </context>
  </mouse>

  <menu>
    <file>menu.xml</file>
    <hideDelay>200</hideDelay>
    <middle>no</middle>
    <submenuShowDelay>100</submenuShowDelay>
    <submenuHideDelay>400</submenuHideDelay>
    <applicationIcons>yes</applicationIcons>
    <manageDesktops>yes</manageDesktops>
  </menu>

</openbox_config>
RCEOF

# --- Openbox right-click menu ---
cat > /etc/skel/.config/openbox/menu.xml << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<openbox_menu xmlns="http://openbox.org/3.4/menu">
  <menu id="root-menu" label="Cryogram OS">
    <item label="CyberDen">
