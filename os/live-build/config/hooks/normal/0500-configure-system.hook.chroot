mkdir -p /etc/skel/.config/gtk-2.0
cat > /etc/skel/.config/gtk-2.0/gtkrc << 'EOF'
gtk-theme-name="Arc-Dark"
gtk-icon-theme-name="Papirus-Dark"
gtk-font-name="Inter 10"
gtk-cursor-theme-name="Adwaita"
EOF

# --- Qt theming ---
mkdir -p /etc/skel/.config/qt5ct
cat > /etc/skel/.config/qt5ct/qt5ct.conf << 'EOF'
[Appearance]
color_scheme_path=/usr/share/qt5ct/colors/darker.conf
custom_palette=false
icon_theme=Papirus-Dark
standard_dialogs=default
style=Adwaita-Dark

[Fonts]
fixed=@Variant(\0\0\0@\0\0\0\x12\0J\0e\0t\0B\0r\0a\0i\0n\0s\0 \0M\0o\0n\0o@$\0\0\0\0\0\0\xff\xff\xff\xff\x5\x1\0\x32\x10)
general=@Variant(\0\0\0@\0\0\0\n\0I\0n\0t\0e\0r@$\0\0\0\0\0\0\xff\xff\xff\xff\x5\x1\0\x32\x10)
EOF

# --- QT platform theme env (system-wide) ---
cat > /etc/profile.d/cryogram-qt.sh << 'EOF'
export QT_QPA_PLATFORMTHEME=qt5ct
export QT_AUTO_SCREEN_SCALE_FACTOR=1
EOF

# --- Shell setup (.bashrc) ---
cat >> /etc/skel/.bashrc << 'EOF'

# ── Cryogram OS ──────────────────────────────────────────────────────────────
export HISTSIZE=50000
export HISTFILESIZE=100000
export HISTCONTROL=ignoredups:erasedups
shopt -s histappend

export PATH="$HOME/.cargo/bin:/usr/local/go/bin:$HOME/.local/bin:$PATH"
export GOPATH="$HOME/go"
export QT_QPA_PLATFORMTHEME=qt5ct

# Aliases
alias ll='ls -lahF --color=auto'
alias la='ls -A --color=auto'
alias grep='grep --color=auto'
alias ip='ip --color=auto'
alias diff='diff --color=auto'
alias nmap='nmap --reason'
alias python='python3'
alias update='sudo apt update && sudo apt upgrade -y'
alias ports='ss -tulpn'
alias myip='curl -s ifconfig.me'

# Cryogram prompt (Kali-style)
CYAN='\[\033[0;36m\]'
GREEN='\[\033[0;32m\]'
RED='\[\033[0;31m\]'
BOLD='\[\033[1m\]'
RESET='\[\033[0m\]'
PS1="${CYAN}┌──${GREEN}(${BOLD}\u${RESET}${GREEN}㉿cryogram${GREEN})${CYAN}─[${RESET}\w${CYAN}]
${CYAN}└─${RED}\$${RESET} "
EOF

# --- Profile PATH ---
cat > /etc/profile.d/cryogram-paths.sh << 'EOF'
export PATH="/usr/local/go/bin:$HOME/.cargo/bin:$HOME/.local/bin:$PATH"
export GOPATH="$HOME/go"
EOF

# --- GRUB configuration ---
cat > /etc/default/grub << 'EOF'
GRUB_DEFAULT=0
GRUB_TIMEOUT=5
GRUB_DISTRIBUTOR="Cryogram OS"
GRUB_CMDLINE_LINUX_DEFAULT="quiet splash"
GRUB_CMDLINE_LINUX=""
GRUB_THEME="/usr/share/grub/themes/cryogram/theme.txt"
GRUB_GFXMODE="1920x1080,auto"
GRUB_GFXPAYLOAD_LINUX=keep
EOF

# --- Hostname ---
echo "cryogram" > /etc/hostname
cat > /etc/hosts << 'EOF'
127.0.0.1   localhost
127.0.1.1   cryogram
::1         localhost ip6-localhost ip6-loopback
ff02::1     ip6-allnodes
ff02::2     ip6-allrouters
EOF

# --- Enable services ---
systemctl enable lightdm       2>/dev/null || true
systemctl enable NetworkManager 2>/dev/null || true
systemctl enable bluetooth     2>/dev/null || true
systemctl enable cups          2>/dev/null || true
systemctl enable tlp           2>/dev/null || true

# --- Disable services that waste resources ---
systemctl disable apt-daily.timer         2>/dev/null || true
systemctl disable apt-daily-upgrade.timer 2>/dev/null || true
systemctl disable ModemManager            2>/dev/null || true

echo "System configuration complete."
