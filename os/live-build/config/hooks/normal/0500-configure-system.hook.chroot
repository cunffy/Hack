# --- Picom config ---
mkdir -p /etc/cryogram
cat > /etc/cryogram/picom.conf << 'EOF'
backend = "glx";
vsync = true;
shadow = true;
shadow-radius = 14;
shadow-offset-x = -7;
shadow-offset-y = -7;
shadow-opacity = 0.55;
shadow-color = "#000000";
shadow-exclude = [
  "class_g = 'tint2'",
  "class_g = 'dunst'"
];
fading = true;
fade-in-step = 0.06;
fade-out-step = 0.06;
fade-delta = 4;
opacity-rule = [
  "94:class_g = 'Alacritty'",
  "94:class_g = 'xfce4-terminal'",
  "98:class_g = 'cyberden'"
];
blur-method = "dual_kawase";
blur-strength = 4;
blur-background = false;
EOF

# --- Tint2 panel config (thin top bar: system tray + clock) ---
mkdir -p /etc/skel/.config/tint2
cat > /etc/skel/.config/tint2/tint2rc << 'EOF'
# Cryogram OS — Tint2 panel configuration

#---- Background definitions ----
rounded = 0
border_width = 0
background_color = #080c12 100
border_color = #00d4ff 0

rounded = 4
border_width = 1
background_color = #0d1421 90
border_color = #1a2840 80

#---- Panel ----
panel_items = S:C
panel_size = 100% 28
panel_margin = 0 0
panel_padding = 6 0 6
panel_background_id = 1
panel_position = top center horizontal
panel_layer = top
panel_monitor = all
autohide = 0
strut_policy = follow_size
panel_window_name = tint2
disable_transparency = 0
mouse_effects = 1
font_shadow = 0

#---- Clock ----
time1_format = %H:%M
time2_format = %a %d %b
time1_font = JetBrains Mono Bold 10
time2_font = JetBrains Mono 8
clock_font_color = #c9d1d9 90
clock_padding = 6 0
clock_background_id = 2
clock_tooltip = %A %d %B %Y

#---- System tray ----
systray_padding = 0 3 6
systray_background_id = 0
systray_sort = ascending
systray_icon_size = 18
systray_icon_asb = 100 0 0
systray_monitor = primary
systray_name_filter =
EOF

# --- Rofi theme (Cryogram dark) ---
mkdir -p /etc/skel/.config/rofi
cat > /etc/skel/.config/rofi/cryogram.rasi << 'EOF'
* {
    bg:       #080c12;
    bg-alt:   #0d1421;
    fg:       #c9d1d9;
    accent:   #00d4ff;
    muted:    #4e5d6e;
    border:   #1a2840;
    red:      #ff4466;

    background-color: transparent;
    text-color:       @fg;
    font:             "JetBrains Mono 11";
}

window {
    background-color: @bg;
    border:           1px solid @border;
    border-radius:    10px;
    width:            480px;
    padding:          8px;
}

mainbox {
    background-color: transparent;
    spacing:          8px;
}

inputbar {
    background-color: @bg-alt;
    border:           1px solid @border;
    border-radius:    7px;
    padding:          8px 12px;
    spacing:          8px;
    children:         [prompt, entry];
}

prompt {
    text-color: @accent;
    font:       "JetBrains Mono Bold 11";
}

entry {
    text-color:        @fg;
    placeholder:       "Type to search…";
    placeholder-color: @muted;
}

listview {
    background-color: transparent;
    lines:            8;
    spacing:          2px;
}

element {
    background-color: transparent;
    border-radius:    6px;
    padding:          8px 12px;
    spacing:          10px;
    orientation:      horizontal;
}

element normal.normal  { background-color: transparent; text-color: @fg; }
element selected.normal { background-color: @bg-alt; border: 1px solid @accent; text-color: @accent; }
element normal.urgent  { text-color: @red; }

element-icon { size: 20px; }
element-text { vertical-align: 0.5; }
EOF

# --- Volume OSD script ---
cat > /usr/local/bin/cryogram-volume << 'EOF'
#!/bin/bash
case "$1" in
  up)   pactl set-sink-volume @DEFAULT_SINK@ +5% ;;
  down) pactl set-sink-volume @DEFAULT_SINK@ -5% ;;
  mute) pactl set-sink-mute @DEFAULT_SINK@ toggle ;;
esac
VOL=$(pactl get-sink-volume @DEFAULT_SINK@ 2>/dev/null | grep -oP '\d+(?=%)' | head -1)
MUTED=$(pactl get-sink-mute @DEFAULT_SINK@ 2>/dev/null | grep -c 'yes' || true)
if [ "${MUTED}" = "1" ]; then
  dunstify -a "Volume" -i audio-volume-muted "Muted" "" -r 9993 -u low -t 1500
else
  VOL=${VOL:-0}
  dunstify -a "Volume" -i audio-volume-high "Volume" "${VOL}%" \
    -h "int:value:${VOL}" -r 9993 -u low -t 1500
fi
EOF
chmod +x /usr/local/bin/cryogram-volume

# --- Brightness OSD script ---
cat > /usr/local/bin/cryogram-brightness << 'EOF'
#!/bin/bash
case "$1" in
  up)   brightnessctl set 5%+ ;;
  down) brightnessctl set 5%- ;;
esac
BRIGHT=$(brightnessctl get 2>/dev/null || echo 100)
MAX=$(brightnessctl max 2>/dev/null || echo 100)
PCT=$(( BRIGHT * 100 / MAX ))
dunstify -a "Brightness" -i display-brightness "Brightness" "${PCT}%" \
  -h "int:value:${PCT}" -r 9994 -u low -t 1500
EOF
chmod +x /usr/local/bin/cryogram-brightness

# --- GTK dark theme ---
mkdir -p /etc/skel/.config/gtk-3.0
cat > /etc/skel/.config/gtk-3.0/settings.ini << 'EOF'
[Settings]
