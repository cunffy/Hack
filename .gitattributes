# Force LF line endings for all shell scripts and text files
# This prevents Windows git from converting LF→CRLF which breaks Docker builds
* text=auto
*.sh text eol=lf
*.chroot text eol=lf
*.binary text eol=lf
*.conf text eol=lf
*.py text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
Dockerfile text eol=lf
