# Force LF line endings for all text files
# Prevents Windows git CRLF conversion breaking Docker/bash scripts
* text=auto eol=lf

# Binaries — never touch these
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.iso binary
*.gz binary
*.zip binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary
*.node binary
